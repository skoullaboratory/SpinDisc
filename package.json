{
  "name": "spindisc",
  "version": "1.1.0",
  "description": "Premium music disc PiP overlay with real-time SMTC synchronization.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder build --win"
  },
  "keywords": [],
  "author": "Danie",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.1.1"
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12"
  },
  "build": {
    "appId": "com.spindisc.app",
    "productName": "SpinDisc",
    "icon": "img/SpinDiscLogo.png",
    "win": {
      "target": "nsis",
      "icon": "img/SpinDiscLogo.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "installerIcon": "img/SpinDiscLogo.png",
      "uninstallerIcon": "img/SpinDiscLogo.png"
    },
    "directories": {
      "output": "dist"
    }
  }
}
